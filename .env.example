# Required runtime directory (also passed as argv)
CODEX_WORKDIR=/path/to/your/workdir

# iMessage channel (macOS + iPhone via iMessage sync)
IMSG_BIN=imsg
IMSG_CHAT_ID=<CLOUDX_CHAT_ID>
IMSG_SEND_CHAT_ID=<CLOUDX_CHAT_ID>
IMSG_SEND_SERVICE=auto
IMSG_FETCH_LIMIT=30
IMSG_INCLUDE_FROM_ME=0

# Optional: override channel commands
# SMS_FETCH_CMD="python3 /abs/path/to/fetch_adapter.py"
# SMS_SEND_CMD="python3 /abs/path/to/send_adapter.py"

# DingTalk channel (bi-directional: callback + app api)
# SMS_FETCH_CMD="python3 /abs/path/to/src/cli_agent_gateway/channels/dingtalk_fetch.py"
# SMS_SEND_CMD="python3 /abs/path/to/src/cli_agent_gateway/channels/dingtalk_send.py"
# DINGTALK_QUEUE_FILE=.dingtalk_inbox.jsonl
# DINGTALK_FETCH_MAX_EVENTS=30
# DINGTALK_DM_POLICY=allowlist
# DINGTALK_GROUP_POLICY=allowlist
# DINGTALK_ALLOWED_FROM=staffA,staffB
# DINGTALK_GROUP_ALLOWLIST=cidA,cidB
# DINGTALK_REQUIRE_MENTION_IN_GROUP=1
# DINGTALK_SEND_MODE=api
# DINGTALK_APP_KEY=...
# DINGTALK_APP_SECRET=...
# DINGTALK_AGENT_ID=123456
# DINGTALK_DEFAULT_TO_USER=staffA
# DINGTALK_TOKEN_URL=https://api.dingtalk.com/v1.0/oauth2/accessToken
# DINGTALK_SEND_URL=https://oapi.dingtalk.com/topapi/message/corpconversation/asyncsend_v2
# DINGTALK_SEND_TIMEOUT_SEC=10
# DINGTALK_BOT_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=...
# DINGTALK_BOT_SECRET=SEC...
# DINGTALK_CALLBACK_HOST=0.0.0.0
# DINGTALK_CALLBACK_PORT=18580
# DINGTALK_CALLBACK_SECRET=...

# Sender authorization
REMOTE_USER_ID=<USER_IMESSAGE_ID>
ALLOWED_FROM=<USER_IMESSAGE_ID>

# ACP execution
ACP_AGENT_CMD="codex-acp"
AGENT_TIMEOUT_SEC=1800
ACP_PERMISSION_POLICY=auto_allow

# Loop behavior
PROCESS_ONLY_LATEST=0
POLL_INTERVAL_SEC=5
PROGRESS_NOTIFY_INTERVAL_SEC=60
SMS_REPLY_MAX_CHARS=8000
REPLY_STYLE_ENABLED=1
REPLY_STYLE_PROMPT="请用 iMessage 友好格式回复：短句优先；先结论后细节；尽量 3-6 行；避免长段落、复杂 Markdown、表格；代码只给最小必要片段；状态词清晰（进行中/阻塞/完成）。"

# Persistence paths
STATE_FILE=.agent_gateway_state.json
REPORT_DIR=.agent_gateway_reports
INTERACTION_LOG_FILE=.agent_gateway_interactions.jsonl
