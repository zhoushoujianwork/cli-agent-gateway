# sms-codex-loop local defaults
# Copy this file to `.env` and fill in your real values.

# Core paths
CODEX_WORKDIR=/path/to/your/codex-workdir

# iMessage adapters
IMSG_CHAT_ID=<CLOUDX_CHAT_ID>
IMSG_SEND_CHAT_ID=<CLOUDX_CHAT_ID>
REMOTE_USER_ID=<USER_IMESSAGE_ID>
LOCAL_UDP_PORT=20098
IMSG_SEND_SERVICE=auto
IMSG_FETCH_LIMIT=30
IMSG_INCLUDE_FROM_ME=0

# Auto-onboarding helper (Cloud X endpoint iMessage ID)
CLOUDX_ID=cloudx@example.com

# Loop commands
SMS_FETCH_CMD="IMSG_CHAT_ID=<CLOUDX_CHAT_ID> /path/to/sms-codex-loop/adapters/imsg_fetch.sh"
SMS_SEND_CMD="/path/to/sms-codex-loop/adapters/imsg_send.sh"

# Runtime behavior
PROCESS_ONLY_LATEST=1
POLL_INTERVAL_SEC=5
CODEX_TIMEOUT_SEC=1800
SMS_REPLY_MAX_CHARS=8000
SMS_HIGHLIGHT_MAX_LINES=20
SEND_STARTUP_NOTIFICATION=1
PROGRESS_NOTIFY_INTERVAL_SEC=60
